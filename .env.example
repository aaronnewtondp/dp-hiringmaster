# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_NAME=dp_hms

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Drive (for JD storage, resume links) ──────────────────────────────
# Create a Service Account in Google Cloud Console, enable Drive API,
# share the Hiring Process folder with the service account email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=1FR2GmDKumRBOQT5Zn0jRpIJ31xI5E8nC

# Folder for auto-generated JD PDFs (Phase 3).
DRIVE_JD_FOLDER_ID=

# Real Workspace user email the service account impersonates for Drive
# uploads, via domain-wide delegation. Required because bare service accounts
# have no Drive storage quota of their own. Set up once: Admin Console →
# Security → API Controls → Domain-wide Delegation → add this service
# account's OAuth Client ID with scope https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_IMPERSONATE_EMAIL=

# ─── Google Calendar (interview scheduling) ────────────────────────────────────
# Reuses the SAME service account credentials as Drive above — no new key, no
# new env var. Impersonation target is dynamic (the logged-in HR user who
# scheduled the round, from their JWT), not a fixed mailbox like Drive's.
# One-time setup: add https://www.googleapis.com/auth/calendar.events to the
# SAME service account's OAuth Client ID entry in Admin Console → Security →
# API Controls → Domain-wide Delegation (additive to the drive.file grant
# above), and enable the Calendar API at the GCP project level.
# GOOGLE_CLIENT_SECRET / GOOGLE_REFRESH_TOKEN below are unused, unrelated
# leftovers from an earlier auth design — Calendar does not need them either.

# ─── Ingestion Webhooks (Google Apps Script → HMS, shared-secret auth) ────────
# Apps Script triggers can't hold a user session, so these ingest routes are
# authenticated via an x-ingest-secret header instead of JWT. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROLE_INGEST_SECRET=
CANDIDATE_INGEST_SECRET=

# Vercel Cron auth — set this in the Vercel project's env vars and Vercel
# automatically sends it as `Authorization: Bearer $CRON_SECRET` to any
# route listed in vercel.json's `crons` array. Only /api/cron/email-digest
# is actually cron-scheduled (8:15am daily) — /api/cron/sla-check exists as
# a manually-callable endpoint but isn't on a schedule, since the frequent
# SLA check runs via dashboard.ts's compute-on-read path instead (Vercel
# Hobby tier cron can't run sub-daily).
CRON_SECRET=

# ─── Email (for SLA digests and notifications) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
HR_EMAIL=aaron.newton@digitalpaani.com

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
