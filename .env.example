# share the Hiring Process folder with the service account email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=1FR2GmDKumRBOQT5Zn0jRpIJ31xI5E8nC

# ─── Email (for SLA digests and notifications) ────────────────────────────────
