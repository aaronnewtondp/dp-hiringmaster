# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_NAME=dp_hms

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Drive (for JD storage, resume links) ──────────────────────────────
# Create a Service Account in Google Cloud Console, enable Drive API,
# share the Hiring Process folder with the service account email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=1FR2GmDKumRBOQT5Zn0jRpIJ31xI5E8nC

# Folder for auto-generated JD PDFs (Phase 3).
DRIVE_JD_FOLDER_ID=

# Real Workspace user email the service account impersonates for Drive
# uploads, via domain-wide delegation. Required because bare service accounts
# have no Drive storage quota of their own. Set up once: Admin Console →
# Security → API Controls → Domain-wide Delegation → add this service
# account's OAuth Client ID with scope https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_IMPERSONATE_EMAIL=

# ─── Email (for SLA digests and notifications) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
HR_EMAIL=aaron.newton@digitalpaani.com

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
